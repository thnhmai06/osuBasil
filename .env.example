# Reference for environment-variable overrides. ASP.NET Core reads Section__Key from the
# environment directly (double underscore = config-section nesting) — there's no docker-compose
# translation layer anymore, so these are the real keys, not the BASIL_* shorthand used before.
# Set them in your shell, a process manager's env config, or appsettings.*.json next to the
# executable.

# Public-facing hostname clients connect to (c./ce./c4./c5./c6./osu./a./b./api. subdomains all hang off this).
ServerBehavior__Domain=localhost

# Prefix chat commands must start with (!help, !roll, !mp ...).
ServerBehavior__CommandPrefix=!

# osu! client's in-game menu icon (top-left) — icon image + click-through URL.
ServerBehavior__MenuIconUrl=https://example.local/icon.png
ServerBehavior__MenuOnclickUrl=https://example.local

# BasilBot's display name. Changing this after first boot renames the seeded id=1 user in-place.
Bot__Name=BasilBot

# Gates every api.<domain> management REST route (beatmap/user/replay/match/seasonal CRUD) via the
# X-Admin-Key header. Leave unset to keep the management API locked down (401 on every request).
Api__AdminKey=

# SQLite database file path. Relative paths are resolved next to the executable. Only override if
# you want the DB file somewhere other than the default (basil.db next to the executable).
Database__Path=basil.db

# Replays/Avatars/Mapsets/Seasonals/Faqs are NOT configurable — they're always fixed folders next
# to the executable (Replays/, Avatars/, Mapsets/, Seasonals/, Faqs/).
