# Copy to .env and customize. docker-compose.yml falls back to the defaults shown here for anything unset.

# Public-facing hostname clients connect to (c./ce./c4./c5./c6./osu./a./b./api. subdomains all hang off this).
BASIL_DOMAIN=localhost

# Prefix chat commands must start with (!help, !roll, !mp ...).
BASIL_COMMAND_PREFIX=!

# osu! client's in-game menu icon (top-left) — icon image + click-through URL.
BASIL_MENU_ICON_URL=https://example.local/icon.png
BASIL_MENU_ONCLICK_URL=https://example.local

# BasilBot's display name. Changing this after first boot renames the seeded id=1 user in-place.
BASIL_BOT_NAME=BasilBot

# Gates every api.<domain> management REST route (beatmap/user/replay/match/seasonal CRUD) via the
# X-Admin-Key header. Leave unset to keep the management API locked down (401 on every request).
BASIL_ADMIN_KEY=

# Local file storage paths (relative to the app's working directory inside the container). Only
# override these if you also update the matching volume mount target in docker-compose.yml.
BASIL_REPLAYS_PATH=.data/osr
BASIL_AVATARS_PATH=.data/avatars
BASIL_MAPSETS_PATH=.data/mapsets
BASIL_SEASONALS_PATH=.data/seasonals
BASIL_FAQS_PATH=.data/faqs
